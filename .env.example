DB_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/nags_search
# Clave segura para sesiones Flask (obligatoria en producción)
# SECRET_KEY=

# URL pública del sitio (Stripe, enlaces de restablecer contraseña, portal)
PUBLIC_BASE_URL=https://autoindex.lat

# Directorio con los PDFs del catálogo (Linux ej.: /srv/autoindex/pdfs)
PDF_DIR=/ruta/absoluta/a/tus/pdfs

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

#SMTP_HOST
#SMTP_PORT (por defecto 587)
#SMTP_USER
#SMTP_PASS
#SMTP_FROM

# WhatsApp para el panel (solo dígitos: código país + número, sin + ni espacios). Ej. México: 5255512345678
# Tras cambiar esto, reinicia Flask (Ctrl+C y vuelve a ejecutar python app.py).
WHATSAPP_PHONE=5611150127

# Linux: suele bastar dejar vacío si `tesseract` y Poppler están en PATH
# TESSERACT_CMD=/usr/bin/tesseract
# POPPLER_PATH=
# Windows (ejemplo):
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# POPPLER_PATH=C:\ruta\a\poppler\Library\bin